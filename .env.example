# CampusBrief — Environment Variables
# Copy this file to .env and fill in your values

# MiniMax API credentials (get from https://platform.minimaxi.com)
API_KEY=sk-your-api-key-here
BASE_URL=https://api.minimaxi.com/v1
MODEL_NAME=MiniMax-M2.5

# Demo mode: true = offline with pre-computed results, false = live AI
DEMO_MODE=true
